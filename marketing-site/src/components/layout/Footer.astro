---
import { useTranslations, localizedPath, type Lang } from '@/i18n/utils';

interface Props {
  pageKey?: string;
  lang?: Lang;
}

const { pageKey = 'crm', lang = 'fr' } = Astro.props;
const t = useTranslations(lang);

const tagline = pageKey === 'marketing'
  ? t('footer.tagline.marketing')
  : t('footer.tagline.crm');

const homeHref = localizedPath('/', lang);
const affiliationHref = localizedPath(
  `/affiliation?plan=${pageKey === 'marketing' ? 'marketing' : 'chatting'}`,
  lang,
);
---

<footer class="footer" role="contentinfo">
  <div class="footer-grid">
    <div class="footer-brand">
      <a href={homeHref} class="footer-logo" aria-label={t('header.logoLabel')}>
        <img src="/assets/images/logo-original.webp" alt="" class="footer-logo-img" />
        <span class="footer-logo-name">SyncAgency</span>
      </a>
      <p class="footer-tagline">{tagline}</p>
      <a href="https://app.syncagency.fr/register" class="footer-cta">{t('footer.cta')}</a>
      <div class="footer-socials">
        <a href="https://taap.it/SyncAgencyy" class="footer-social-link" aria-label="YouTube" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/>
            <path d="m10 15 5-3-5-3z"/>
          </svg>
        </a>
        <a href="https://taap.it/SyncAgencyyy" class="footer-social-link" aria-label="Instagram" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
          </svg>
        </a>
        <a href="https://taap.it/pvzlucas" class="footer-social-link" aria-label="Telegram" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m22 2-7 20-4-9-9-4Z"/>
            <path d="M22 2 11 13"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer-col">
      <p class="footer-col-title">{t('footer.col.solutions')}</p>
      <a href={homeHref} class="footer-link">{t('nav.crm')}</a>
      <a href={localizedPath('/marketing', lang)} class="footer-link">{t('nav.marketing')}</a>
      <a href="#" class="footer-link footer-link--soon">{t('nav.empireOs')} <span class="footer-badge-soon">{t('nav.soon')}</span></a>
    </div>

    <div class="footer-col">
      <p class="footer-col-title">{t('footer.col.resources')}</p>
      <a href={localizedPath('/blog', lang)} class="footer-link">{t('footer.blog')}</a>
      <a href={localizedPath('/about', lang)} class="footer-link">{t('nav.about')}</a>
      <a href={localizedPath('/migration-infloww', lang)} class="footer-link">{t('footer.migration')}</a>
    </div>

    <div class="footer-col">
      <p class="footer-col-title">{t('footer.col.account')}</p>
      <a href="https://app.syncagency.fr/login" class="footer-link">{t('footer.signIn')}</a>
      <a href="https://app.syncagency.fr/register" class="footer-link">{t('footer.signUp')}</a>
      <a href={affiliationHref} class="footer-link">{t('footer.affiliation')}</a>
      <a href="https://taap.it/provenzanolucas" class="footer-link" target="_blank" rel="noopener">{t('footer.contact')}</a>
    </div>

    <div class="footer-col">
      <p class="footer-col-title">{t('footer.col.legal')}</p>
      <a href={localizedPath('/cgu', lang)} class="footer-link">{t('footer.cgu')}</a>
      <a href={localizedPath('/cgv', lang)} class="footer-link">{t('footer.cgv')}</a>
      <a href={localizedPath('/privacy', lang)} class="footer-link">{t('footer.privacy')}</a>
      {lang === 'en' && (
        <a href={localizedPath('/cookies', lang)} class="footer-link">{t('footer.cookies')}</a>
      )}
    </div>
  </div>

  <div class="footer-bottom">
    <span>{t('footer.copyright')}</span>
  </div>
</footer>
