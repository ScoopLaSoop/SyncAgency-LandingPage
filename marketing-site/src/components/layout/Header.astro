---
import { useTranslations, localizedPath, type Lang } from '@/i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  pageKey?: string;
  lang?: Lang;
}

const { pageKey = 'crm', lang = 'fr' } = Astro.props;
const t = useTranslations(lang);

const isLandingPage = pageKey === 'crm' || pageKey === 'marketing';
const pricingHref = isLandingPage ? '#pricing' : localizedPath('/', lang) + '#pricing';
const faqHref = isLandingPage ? '#faq' : localizedPath('/', lang) + '#faq';
const headerCtaAttr = pageKey === 'marketing' ? 'header-7j-gratuits' : '7_jours_gratuits';

const homeHref = localizedPath('/', lang);
const marketingHref = localizedPath('/marketing', lang);
const aboutHref = localizedPath('/about', lang);
const affiliationHref = localizedPath(
  `/affiliation?plan=${pageKey === 'marketing' ? 'marketing' : 'chatting'}`,
  lang,
);
---

<header class="header" id="header">
  <a href={homeHref} class="header-logo" aria-label={t('header.logoLabel')}>
    <img src="/assets/images/logo-original.webp" alt="" class="header-logo-img" />
    <span class="header-logo-name">SyncAgency</span>
  </a>
  <nav class="header-nav" aria-label={t('header.navLabel')}>
    <div class="nav-dropdown" id="navProductDropdown">
      <button class="nav-dropdown-btn" id="navProductBtn" aria-haspopup="true" aria-expanded="false">
        {t('nav.product')} <i data-lucide="chevron-down" class="nav-chevron" aria-hidden="true"></i>
      </button>
      <div class="nav-dropdown-panel" role="menu">
        <a href={homeHref} class="nav-dropdown-item" role="menuitem">{t('nav.crm')}</a>
        <a href={marketingHref} class="nav-dropdown-item" role="menuitem">{t('nav.marketing')}</a>
        <a href="#" class="nav-dropdown-item nav-dropdown-item--disabled" role="menuitem" aria-disabled="true">
          {t('nav.empireOs')} <span class="footer-badge-soon">{t('nav.soon')}</span>
        </a>
      </div>
    </div>
    <a href={affiliationHref} class="header-nav-link">{t('nav.affiliation')}</a>
    <a href={aboutHref} class="header-nav-link">{t('nav.about')}</a>
    <a href={pricingHref} class="header-nav-link">{t('nav.pricing')}</a>
    <a href={faqHref} class="header-nav-link">{t('nav.faq')}</a>
  </nav>
  <div class="header-actions">
    <a href="https://app.syncagency.fr/login" class="header-nav-link header-login">{t('nav.login')}</a>
    <LanguageSwitcher lang={lang} />
    <a href={pricingHref} class="btn-primary" data-cta={headerCtaAttr} data-section="header">{t('nav.ctaTrial')}</a>
  </div>
  <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label={t('header.menuLabel')} aria-expanded="false">
    <i data-lucide="menu" class="menu-icon"></i>
  </button>
</header>

<div class="mobile-nav" id="mobileNav" role="navigation" aria-label={t('header.mobileNavLabel')} aria-hidden="true">
  <p class="mobile-nav-group-title">{t('nav.product')}</p>
  <a href={homeHref} class="mobile-nav-link">{t('nav.crm')}</a>
  <a href={marketingHref} class="mobile-nav-link">{t('nav.marketing')}</a>
  <a href="#" class="mobile-nav-link mobile-nav-link--disabled">
    {t('nav.empireOs')} <span class="mobile-nav-soon">{t('nav.soon')}</span>
  </a>
  <a href={affiliationHref} class="mobile-nav-link">{t('nav.affiliation')}</a>
  <a href={aboutHref} class="mobile-nav-link">{t('nav.about')}</a>
  <a href={pricingHref} class="mobile-nav-link">{t('nav.pricing')}</a>
  <a href={faqHref} class="mobile-nav-link">{t('nav.faq')}</a>
  <div class="mobile-nav-actions">
    <a href="https://app.syncagency.fr/login" class="mobile-nav-link">{t('nav.login')}</a>
    <a href={pricingHref} class="btn-primary" data-cta={headerCtaAttr} data-section="mobile_nav">{t('nav.ctaTrial')}</a>
  </div>
</div>

<script>
  var navProductBtn = document.getElementById('navProductBtn');
  var navProductDropdown = document.getElementById('navProductDropdown');
  if (navProductBtn && navProductDropdown) {
    var dropdownPanel = navProductDropdown.querySelector('.nav-dropdown-panel');

    navProductBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      var isOpen = navProductDropdown.classList.contains('open');
      navProductDropdown.classList.toggle('open', !isOpen);
      navProductBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    document.addEventListener('click', function () {
      if (navProductDropdown.classList.contains('open')) {
        navProductDropdown.classList.remove('open');
        navProductBtn.setAttribute('aria-expanded', 'false');
      }
    });

    if (dropdownPanel) {
      dropdownPanel.addEventListener('click', function (e) { e.stopPropagation(); });
    }

    navProductBtn.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        navProductDropdown.classList.remove('open');
        navProductBtn.setAttribute('aria-expanded', 'false');
        navProductBtn.focus();
      }
    });
  }
</script>
