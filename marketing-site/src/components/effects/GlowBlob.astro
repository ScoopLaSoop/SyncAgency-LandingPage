---
interface Props {
  color?: string;  // ex: 'rgba(59,91,255,0.15)'
  size?: string;   // ex: '600px'
  top?: string;
  left?: string;
  right?: string;
  bottom?: string;
  delay?: string;  // ex: '2s'
  class?: string;
}
const { color, size = '500px', top, left, right, bottom, delay = '0s', class: className } = Astro.props;
const style = [
  color && `--blob-color: ${color}`,
  size && `--blob-size: ${size}`,
  top && `top: ${top}`,
  left && `left: ${left}`,
  right && `right: ${right}`,
  bottom && `bottom: ${bottom}`,
  delay && `animation-delay: ${delay}`,
].filter(Boolean).join('; ');
---
<div class={`glow-blob${className ? ' ' + className : ''}`} style={style} aria-hidden="true"></div>
