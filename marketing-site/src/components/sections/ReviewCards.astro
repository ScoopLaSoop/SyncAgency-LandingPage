---
interface ReviewCard {
  name: string;
  context: string;
  avatar?: string;
  stars?: number;
  beforeLabel?: string;
  afterLabel?: string;
  beforeQuote: string;
  afterQuote?: string;
}

interface Props {
  mode?: 'crm' | 'marketing';
  title: string;
  subtitle?: string;
  trust: string[];
  cards: ReviewCard[];
  transitionText?: string;
}

const { mode = 'crm', title, subtitle, trust, cards, transitionText } = Astro.props;

const trustIcons = ['check-circle-2', 'trending-up', 'heart'];

function renderStars(n: number = 5): string {
  return '★'.repeat(Math.min(5, Math.max(0, n)));
}
---

<section class={`section${mode === 'marketing' ? ' mktg-section--reviews' : ' section--testimonial'}`} id={mode === 'marketing' ? 'avis' : 'temoignage'}>
  <div class="container">
    <h2 class="section-title fade-in-up" set:html={title} />
    {subtitle && <p class="section-subtitle fade-in-up delay-1" set:html={subtitle} />}

    <div class="review-trust-row fade-in-up delay-1">
      {trust.map((item, i) => (
        <span class="review-trust-item">
          <i data-lucide={trustIcons[i] ?? 'check-circle-2'} aria-hidden="true"></i> {item}
        </span>
      ))}
    </div>

    {mode === 'crm' ? (
      <div class="testi-grid fade-in-up delay-2">
        <div class="testi-video-wrap">
          <div class="testi-video-card" id="testiVideoCard">
            <video
              class="solution-video"
              id="testiVideo"
              playsinline
              preload="metadata"
              poster="/assets/images/testi-review-poster.jpg"
              controlsList="nofullscreen nodownload noremoteplayback"
            >
              <source src="/assets/videos/testi-review.mp4" type="video/mp4" />
            </video>
            <div class="testi-video-overlay" id="testiOverlay" role="button" aria-label="Lire le témoignage" tabindex="0">
              <div class="testi-video-play">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
          </div>
        </div>
        <div class="testi-reviews">
          {cards.map((card) => (
            <div class="review-card">
              <div class="review-card-header">
                {card.avatar && (
                  <img src={card.avatar} alt={card.name} class="review-avatar-photo" width="48" height="48" loading="lazy" />
                )}
                <div>
                  <strong class="review-card-name">{card.name}</strong>
                </div>
              </div>
              <div class="review-stars">{renderStars(card.stars ?? 5)}</div>
              <p class="review-card-text" set:html={card.beforeQuote} />
            </div>
          ))}
        </div>
      </div>
    ) : (
      <div class="mktg-review-grid-2 fade-in-up delay-2">
        {cards.map((card) => (
          <div class="review-card">
            <div class="review-card-header">
              {card.avatar && (
                <img src={card.avatar} alt={card.name} class="review-avatar-photo" width="48" height="48" />
              )}
              <div>
                <strong class="review-card-name">{card.name}</strong>
                {card.context && <span class="review-card-sub">{card.context}</span>}
              </div>
            </div>
            <div class="review-stars">{renderStars(card.stars ?? 5)}</div>
            <p class="review-card-text" set:html={card.beforeQuote} />
          </div>
        ))}
      </div>
    )}

    {transitionText && (
      <p class="pivot-phrase fade-in-up" set:html={transitionText} />
    )}
  </div>
</section>
