---
interface PivotData {
  line1: string;
  line2: string;
  supportText: string;
  transitionTitle: string;
}

interface Props {
  data: PivotData;
}

const { data } = Astro.props;
---

<section class="section section--key spotlight-zone" id="pivot">
  <div class="glow-blobs">
    <div class="glow-blob glow-blob-1"></div>
    <div class="glow-blob glow-blob-2"></div>
  </div>
  <div class="container container--billboard pivot-content">
    <h2 class="pivot-title">
      <div class="pivot-line-wrap">
        <span class="pivot-line1 pivot-reveal">{data.line1}</span>
      </div>
      <div class="pivot-line-wrap">
        <span class="pivot-line2 text-shimmer pivot-reveal pivot-delay-1">{data.line2}</span>
      </div>
    </h2>
    <div class="pivot-sep"></div>
    <p class="pivot-support pivot-reveal pivot-delay-2" set:html={data.supportText} />
    <h2 class="solution-intro-title pivot-reveal pivot-delay-3">{data.transitionTitle}</h2>
  </div>
</section>
