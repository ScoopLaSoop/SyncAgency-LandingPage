---
interface Bullet {
  label: string;       // texte en gras (ex: "Connexion en QR code :")
  text: string;        // suite du texte
}

interface SolutionItem {
  eyebrow: string;
  title: string;
  description: string;
  bullets: Bullet[];
  microCta?: string;   // texte du lien (ex: "Voir comment connecter un compte")
  videoSrc?: string;   // chemin vers la vidéo
}

interface Props {
  introTitle?: string;
  items: SolutionItem[];
  idPrefix?: string;
  mode?: 'crm' | 'marketing';
}

const { introTitle, items, idPrefix = 'solution-', mode = 'crm' } = Astro.props;
const ctaClass = mode === 'marketing' ? 'btn-tertiary mktg-micro-cta' : 'btn-tertiary';

// index pair (0, 2, 4…) → section--solution-odd (#080808), vidéo gauche / texte droite
// index impair (1, 3, 5…) → section--solution-even (#0A0D1A), vidéo droite / texte gauche (--reverse)
---

<section class="section section--solution-intro" id="solution">
  {items.map((item, index) => {
    const isReverse = index % 2 !== 0;
    const sectionClass = isReverse ? 'section section--solution-even' : 'section section--solution-odd';
    const layoutClass = isReverse ? 'solution-layout solution-layout--reverse' : 'solution-layout';

    const videoBlockFirst = (
      <div class="fade-in-up">
        {item.videoSrc ? (
          <div class="solution-video-card" data-video-toggle>
            <video class="solution-video" muted loop playsinline preload="none">
              <source src={item.videoSrc} type="video/mp4" />
              <track kind="captions" />
            </video>
          </div>
        ) : (
          <div class="solution-video-card mktg-video-ph">
            <div class="mktg-ph-inner">
              <i data-lucide="video"></i>
              <span>VIDÉO À VENIR</span>
            </div>
          </div>
        )}
      </div>
    );

    const videoBlockSecond = (
      <div class="fade-in-up delay-1">
        {item.videoSrc ? (
          <div class="solution-video-card" data-video-toggle>
            <video class="solution-video" muted loop playsinline preload="none">
              <source src={item.videoSrc} type="video/mp4" />
              <track kind="captions" />
            </video>
          </div>
        ) : (
          <div class="solution-video-card mktg-video-ph">
            <div class="mktg-ph-inner">
              <i data-lucide="video"></i>
              <span>VIDÉO À VENIR</span>
            </div>
          </div>
        )}
      </div>
    );

    const textBlockFirst = (
      <div class="fade-in-up">
        <p class="eyebrow" set:html={item.eyebrow} />
        <h3 class="solution-h2" set:html={item.title} />
        <p class="solution-desc" set:html={item.description} />
        <ul class="bullet-list" role="list">
          {item.bullets.map((bullet) => (
            <li>
              <i data-lucide="check-circle-2" class="check-icon" aria-hidden="true"></i>
              <span>
                {bullet.label && <strong>{bullet.label}</strong>}
                {bullet.text}
              </span>
            </li>
          ))}
        </ul>
        {item.microCta && (
          <a href="#pricing" class={ctaClass}>
            {item.microCta} <span class="arrow">→</span>
          </a>
        )}
      </div>
    );

    const textBlockSecond = (
      <div class="fade-in-up delay-1">
        <p class="eyebrow" set:html={item.eyebrow} />
        <h3 class="solution-h2" set:html={item.title} />
        <p class="solution-desc" set:html={item.description} />
        <ul class="bullet-list" role="list">
          {item.bullets.map((bullet) => (
            <li>
              <i data-lucide="check-circle-2" class="check-icon" aria-hidden="true"></i>
              <span>
                {bullet.label && <strong>{bullet.label}</strong>}
                {bullet.text}
              </span>
            </li>
          ))}
        </ul>
        {item.microCta && (
          <a href="#pricing" class={ctaClass}>
            {item.microCta} <span class="arrow">→</span>
          </a>
        )}
      </div>
    );

    return (
      <div class={sectionClass} id={`${idPrefix}${index + 1}`}>
        <div class="container">
          <div class={layoutClass}>
            {isReverse ? (
              <>
                {textBlockFirst}
                {videoBlockSecond}
              </>
            ) : (
              <>
                {videoBlockFirst}
                {textBlockSecond}
              </>
            )}
          </div>
        </div>
      </div>
    );
  })}
</section>
