---
interface HeroData {
  eyebrow: string;
  h1: string;
  subtitle: string;
  ctaText: string;
  ctaUrl: string;
  reassurance: string;
  proofBadge: string;
  vslSrc?: string;
  vslPoster?: string;
}

interface Props {
  data: HeroData;
  pageKey?: 'crm' | 'marketing';
  ctaDataAttr?: string;
}

const { data, pageKey = 'crm', ctaDataAttr = 'hero-cta' } = Astro.props;

const isMarketing = pageKey === 'marketing';
const vslId = isMarketing ? 'vslMarketing' : 'vslChatting';
const vslWrapperId = isMarketing ? 'vslMarketingWrap' : 'vslChattingWrap';
const vslOverlayId = isMarketing ? 'vslMarketingOverlay' : 'vslChattingOverlay';
---

<section class="section section--hero spotlight-zone" id="hero">
  <div class="glow-blobs">
    <div class="glow-blob glow-blob-1"></div>
    <div class="glow-blob glow-blob-2"></div>
  </div>
  <div class={`container hero-inner${isMarketing ? ' mktg-hero-reversed' : ''}`}>

    {isMarketing ? (
      <>
        <!-- Marketing : VSL à gauche, texte à droite -->
        <div class="hero-vsl-col fade-in-up delay-2">
          {data.vslSrc && (
            <div class="vsl-video-wrap" id={vslWrapperId}>
              <video
                class="vsl-video"
                id={vslId}
                playsinline
                preload="metadata"
                poster={data.vslPoster}
                controlsList="nofullscreen nodownload noremoteplayback"
              >
                <source src={data.vslSrc} type="video/mp4" />
              </video>
              <div
                class="vsl-video-overlay"
                id={vslOverlayId}
                role="button"
                aria-label="Lire la vidéo de présentation"
                tabindex="0"
              >
                <div class="testi-video-play">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
            </div>
          )}
          <div class="hero-cta-group hero-cta-mobile">
            <a href={data.ctaUrl} class="btn-primary" data-cta={ctaDataAttr} data-section="hero_mobile">
              {data.ctaText}
            </a>
            <p class="hero-reassurance">{data.reassurance}</p>
          </div>
        </div>

        <div class="hero-text fade-in-up">
          <p class="hero-eyebrow eyebrow eyebrow--animated" set:html={data.eyebrow} />
          <h1 class="hero-h1">{data.h1}</h1>
          <p class="hero-subtitle" set:html={data.subtitle} />
          <div class="hero-cta-group hero-cta-desktop">
            <a href={data.ctaUrl} class="btn-primary" data-cta={ctaDataAttr} data-section="hero">
              {data.ctaText}
            </a>
            <p class="hero-reassurance">{data.reassurance}</p>
          </div>
        </div>
      </>
    ) : (
      <>
        <!-- CRM : texte à gauche, VSL à droite -->
        <div class="hero-text fade-in-up">
          <p class="hero-eyebrow eyebrow eyebrow--animated" set:html={data.eyebrow} />
          <h1 class="hero-h1">{data.h1}</h1>
          <p class="hero-subtitle" set:html={data.subtitle} />
          <div class="hero-cta-group hero-cta-desktop">
            <a href={data.ctaUrl} class="btn-primary" data-cta={ctaDataAttr} data-section="hero">
              {data.ctaText}
            </a>
            <p class="hero-reassurance">{data.reassurance}</p>
          </div>
        </div>

        <div class="fade-in-up delay-2">
          {data.vslSrc && (
            <div class="vsl-video-wrap" id={vslWrapperId}>
              <video
                class="vsl-video"
                id={vslId}
                playsinline
                preload="metadata"
                poster={data.vslPoster}
                controlsList="nofullscreen nodownload noremoteplayback"
              >
                <source src={data.vslSrc} type="video/mp4" />
              </video>
              <div
                class="vsl-video-overlay"
                id={vslOverlayId}
                role="button"
                aria-label="Lire la vidéo de présentation"
                tabindex="0"
              >
                <div class="testi-video-play">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
            </div>
          )}
          <div class="hero-cta-group hero-cta-mobile">
            <a href={data.ctaUrl} class="btn-primary" data-cta={ctaDataAttr} data-section="hero_mobile">
              {data.ctaText}
            </a>
            <p class="hero-reassurance">{data.reassurance}</p>
          </div>
        </div>
      </>
    )}

  </div>
</section>
