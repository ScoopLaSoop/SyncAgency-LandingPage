---
import BaseLayout from '@/layouts/BaseLayout.astro';
const articles = [
  { title: "SyncAgency vs Infloww : Le comparatif complet 2026", slug: "syncagency-vs-infloww", date: "10-05-2026", excerpt: "Tableau de bord complet pour choisir entre SyncAgency et Infloww pour ton agence OFM." },
  { title: "Google Sheet pour agence OFM : pourquoi c'est mathématiquement impossible de scaler", slug: "google-sheet-agence-ofm-pas-scaler", date: "10-05-2026", excerpt: "Analyse des 4 douleurs du tracking manuel et pourquoi un vrai CRM change tout." },
  { title: "Processeur de paiement pour agence OFM : Dropp Fans vs SyncAgency vs Stripe", slug: "processeur-paiement-ofm-comparatif", date: "10-05-2026", excerpt: "Comparatif chiffré des solutions de paiement pour agences OnlyFans Management." }
];

const schemaCollection = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Blog SyncAgency",
  "description": "Articles sur le CRM Telegram pour agences OFM, l'acquisition Instagram/TikTok, et les outils de paiement.",
  "url": "https://www.syncagency.fr/blog",
  "inLanguage": "fr-FR",
  "isPartOf": { "@id": "https://www.syncagency.fr/#organization" },
  "hasPart": articles.map((a) => ({
    "@type": "BlogPosting",
    "headline": a.title,
    "url": `https://www.syncagency.fr/blog/${a.slug}`,
    "description": a.excerpt,
  })),
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://www.syncagency.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.syncagency.fr/blog" },
  ],
};
---
<BaseLayout title="Blog SyncAgency — CRM et Marketing pour agences OFM" description="Articles sur le CRM Telegram pour agences OFM, l'acquisition Instagram/TikTok, et les outils de paiement." pageKey="crm" ogImage="/og/og-blog.png">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaCollection)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  </Fragment>
  <section class="section section--pain" id="blog">
    <div class="container">
      <div style="text-align:center;margin-bottom:56px;">
        <p style="font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#8AA5FF;margin-bottom:12px;">Blog</p>
        <h1 class="section-title">Ressources pour agences OFM</h1>
        <p class="section-subtitle">Guides, comparatifs et stratégies pour scaler ton agence OFM.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px;max-width:960px;margin:0 auto;">
        {articles.map(a => (
          <a href={`/blog/${a.slug}`} style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:20px;padding:28px;text-decoration:none;transition:border-color 0.2s;color:inherit;">
            <p style="font-size:11px;color:#8AA5FF;margin-bottom:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">{a.date}</p>
            <h2 style="font-size:18px;font-weight:700;color:#F2F2F2;margin-bottom:10px;line-height:1.3;">{a.title}</h2>
            <p style="font-size:14px;color:#999;line-height:1.6;">{a.excerpt}</p>
            <p style="margin-top:16px;font-size:13px;color:#8AA5FF;font-weight:500;">Lire l'article →</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
