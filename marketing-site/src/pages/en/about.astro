---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout lang="en"
  title="About SyncAgency — The CRM for creator talent agencies"
  description="SyncAgency: the CRM for creator talent agencies managing operations on Telegram and WhatsApp. Our mission, story, and the team behind the product."
  pageKey="about"
  ogImage="/og/og-about.png"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "url": "https://www.syncagency.fr/en/about",
      "name": "About SyncAgency",
      "mainEntity": {
        "@id": "https://www.syncagency.fr/#organization"
      },
      "description": "About SyncAgency: mission, story, team, and contact information for the CRM built for creator talent agencies on Telegram.",
      "datePublished": "2026-05-10",
      "dateModified": "2026-05-10"
    })} />
  </Fragment>

  <!-- Section 1 — Hero -->
  <section class="section section--hero spotlight-zone" style="min-height: 60vh; display: flex; align-items: center;">
    <div class="glow-blobs">
      <div class="glow-blob glow-blob-1"></div>
      <div class="glow-blob glow-blob-2"></div>
    </div>
    <div class="container fade-in-up" style="max-width: 800px; text-align: center;">
      <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #8AA5FF; margin-bottom: 16px;">About</p>
      <h1 style="font-size: 52px; font-weight: 800; line-height: 1.1; color: #F2F2F2; margin-bottom: 24px;">
        SyncAgency — The CRM for modern creator talent agencies.
      </h1>
      <p style="font-size: 18px; color: #999; line-height: 1.7; max-width: 600px; margin: 0 auto;">
        SyncAgency is the only tool built specifically for agencies managing creators on Telegram and WhatsApp. Launched in 2026, headquartered in the United States.
      </p>
    </div>
  </section>

  <!-- Section 2 — Mission -->
  <section class="section" style="background: #080808;">
    <div class="container fade-in-up" style="max-width: 760px; text-align: center;">
      <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #8AA5FF; margin-bottom: 16px;">Our mission</p>
      <h2 class="section-title" style="margin-bottom: 24px;">Give creator agencies the tools they deserve.</h2>
      <p style="font-size: 17px; color: #999; line-height: 1.8; margin-bottom: 20px;">
        We spent months watching creator agencies run their entire operation on Telegram and WhatsApp with a Google Sheet and twelve open tabs. Serious teams, high-performing creators, but a tech stack that couldn't keep up.
      </p>
      <p style="font-size: 17px; color: #999; line-height: 1.8;">
        SyncAgency was born from that frustration: give creator talent agencies a real CRM built for their reality, off-platform messaging. Not a generic CRM adapted after the fact, just a tool built from the ground up, for the field.
      </p>
    </div>
  </section>

  <!-- Section 3 — Stats -->
  <section class="section section--key" style="background: #050505;">
    <div class="container fade-in-up">
      <div style="text-align: center; margin-bottom: 56px;">
        <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #8AA5FF; margin-bottom: 16px;">By the numbers</p>
        <h2 class="section-title">SyncAgency in numbers.</h2>
      </div>
      <div class="about-stats-grid">
        <div class="about-stat-card">
          <p class="about-stat-number">7</p>
          <p class="about-stat-label">Client agencies</p>
        </div>
        <div class="about-stat-card">
          <p class="about-stat-number">11</p>
          <p class="about-stat-label">Creators managed</p>
        </div>
        <div class="about-stat-card">
          <p class="about-stat-number">11</p>
          <p class="about-stat-label">Active operators</p>
        </div>
        <div class="about-stat-card">
          <p class="about-stat-number">564K+</p>
          <p class="about-stat-label">Messages processed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4 — Story -->
  <section class="section" style="background: #080808;">
    <div class="container fade-in-up" style="max-width: 760px;">
      <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #8AA5FF; margin-bottom: 16px;">Our story</p>
      <h2 class="section-title" style="margin-bottom: 48px;">From idea to product.</h2>
      <div class="about-timeline">
        <div class="about-timeline-item">
          <div class="about-timeline-dot"></div>
          <div class="about-timeline-content">
            <p class="about-timeline-date">2025</p>
            <p class="about-timeline-text">First observation of the problem: no CRM adapted to creator agencies managing direct monetization on Telegram and WhatsApp.</p>
          </div>
        </div>
        <div class="about-timeline-item">
          <div class="about-timeline-dot"></div>
          <div class="about-timeline-content">
            <p class="about-timeline-date">2025</p>
            <p class="about-timeline-text">First functional prototype. Early agencies test the centralized Telegram inbox.</p>
          </div>
        </div>
        <div class="about-timeline-item">
          <div class="about-timeline-dot"></div>
          <div class="about-timeline-content">
            <p class="about-timeline-date">2026</p>
            <p class="about-timeline-text">First active client. Product-market fit validated on Telegram operations management.</p>
          </div>
        </div>
        <div class="about-timeline-item">
          <div class="about-timeline-dot"></div>
          <div class="about-timeline-content">
            <p class="about-timeline-date">May 2026</p>
            <p class="about-timeline-text">7 client agencies, 11 creators managed, 564K+ messages processed. Launch of the Growth Marketing module (Instagram/TikTok/Twitter scraping).</p>
          </div>
        </div>
        <div class="about-timeline-item">
          <div class="about-timeline-dot about-timeline-dot--future"></div>
          <div class="about-timeline-content">
            <p class="about-timeline-date" style="color: #8AA5FF;">Coming soon</p>
            <p class="about-timeline-text">Empire OS: Operations + Marketing + Payments in a single plan. Free assisted migration from any previous CRM.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5 — Team -->
  <section class="section section--key" style="background: #050505;">
    <div class="container fade-in-up">
      <div style="text-align: center; margin-bottom: 56px;">
        <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #8AA5FF; margin-bottom: 16px;">The team</p>
        <h2 class="section-title">The people behind SyncAgency.</h2>
      </div>
      <div style="display: flex; justify-content: center;">
        <div class="about-team-card">
          <img src="/assets/images/lucas-avatar.jpg" alt="Lucas Provenzano — Founder SyncAgency" class="about-team-photo" width="100" height="100" loading="lazy" />
          <h3 class="about-team-name">Lucas Provenzano</h3>
          <p class="about-team-role">Founder &amp; CEO</p>
          <p class="about-team-bio">
            Founder and CEO of SyncAgency. After watching creator agencies struggle with spreadsheets and tools that were never built for Telegram messaging, I decided to build the CRM that was missing.
          </p>
          <div class="about-team-links">
            <a href="https://www.linkedin.com/in/lucas-provenzanooo/" class="about-team-link" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <a href="https://taap.it/pvzlucas" class="about-team-link" target="_blank" rel="noopener" aria-label="Telegram">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
              Telegram
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6 — Contact -->
  <section class="section" style="background: #080808;">
    <div class="container fade-in-up" style="max-width: 640px; text-align: center;">
      <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #8AA5FF; margin-bottom: 16px;">Contact</p>
      <h2 class="section-title" style="margin-bottom: 24px;">A question? We'll answer.</h2>
      <p style="font-size: 16px; color: #999; line-height: 1.7; margin-bottom: 40px;">
        For any question about the product, pricing, or migration from your current CRM — the team is available on Telegram within 24h.
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="mailto:contact@syncagency.fr" class="btn-secondary">contact@syncagency.fr</a>
        <a href="https://taap.it/pvzlucas" class="btn-primary" target="_blank" rel="noopener" data-cta="about_contact" data-section="about">
          Message us on Telegram →
        </a>
      </div>
      <p style="font-size: 13px; color: #555; margin-top: 32px;">
        Registered office: 1209 Mountain Rd Pl NE Ste H, Albuquerque, NM 87110, United States
      </p>
    </div>
  </section>

  <style>
    .about-stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    .about-stat-card {
      background: rgba(138,165,255,0.06);
      border: 1px solid rgba(138,165,255,0.12);
      border-radius: 16px;
      padding: 32px 24px;
      text-align: center;
    }
    .about-stat-number {
      font-size: 48px;
      font-weight: 800;
      color: #8AA5FF;
      line-height: 1;
      margin-bottom: 8px;
    }
    .about-stat-label {
      font-size: 13px;
      color: #999;
      font-weight: 500;
    }
    .about-timeline {
      display: flex;
      flex-direction: column;
      gap: 0;
      position: relative;
      padding-left: 32px;
    }
    .about-timeline::before {
      content: '';
      position: absolute;
      left: 7px;
      top: 8px;
      bottom: 8px;
      width: 1px;
      background: rgba(138,165,255,0.2);
    }
    .about-timeline-item {
      position: relative;
      padding-left: 28px;
      padding-bottom: 40px;
    }
    .about-timeline-item:last-child { padding-bottom: 0; }
    .about-timeline-dot {
      position: absolute;
      left: -32px;
      top: 6px;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #8AA5FF;
      border: 2px solid #050505;
      box-shadow: 0 0 0 3px rgba(138,165,255,0.25);
    }
    .about-timeline-dot--future {
      background: rgba(138,165,255,0.3);
      border: 2px solid #8AA5FF;
    }
    .about-timeline-date {
      font-size: 12px;
      font-weight: 600;
      color: #555;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 6px;
    }
    .about-timeline-text {
      font-size: 16px;
      color: #999;
      line-height: 1.7;
    }
    .about-team-card {
      background: rgba(138,165,255,0.04);
      border: 1px solid rgba(138,165,255,0.12);
      border-radius: 24px;
      padding: 48px 40px;
      text-align: center;
      max-width: 420px;
    }
    .about-team-photo {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      margin-bottom: 20px;
      border: 2px solid rgba(138,165,255,0.3);
    }
    .about-team-name {
      font-size: 22px;
      font-weight: 700;
      color: #F2F2F2;
      margin-bottom: 4px;
    }
    .about-team-role {
      font-size: 14px;
      color: #8AA5FF;
      font-weight: 500;
      margin-bottom: 16px;
    }
    .about-team-bio {
      font-size: 15px;
      color: #999;
      line-height: 1.7;
      margin-bottom: 24px;
    }
    .about-team-links {
      display: flex;
      gap: 12px;
      justify-content: center;
    }
    .about-team-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: #999;
      text-decoration: none;
      padding: 6px 14px;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 20px;
      transition: color 0.2s, border-color 0.2s;
    }
    .about-team-link:hover { color: #F2F2F2; border-color: rgba(138,165,255,0.4); }
    @media (max-width: 768px) {
      .about-stats-grid { grid-template-columns: repeat(2, 1fr); }
      .about-stat-number { font-size: 36px; }
      .about-team-card { padding: 32px 24px; }
    }
  </style>

</BaseLayout>
