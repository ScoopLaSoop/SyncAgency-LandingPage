---
import BaseLayout from '@/layouts/BaseLayout.astro';

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.syncagency.fr/en" },
    { "@type": "ListItem", "position": 2, "name": "Migration from Infloww", "item": "https://www.syncagency.fr/en/migration-infloww" }
  ]
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How long does the migration take?", "acceptedAnswer": { "@type": "Answer", "text": "Usually 24 to 48 hours depending on data volume. A SyncAgency team member walks you through it step by step. You don't migrate alone." } },
    { "@type": "Question", "name": "What about my Infloww data — history, contacts, scripts?", "acceptedAnswer": { "@type": "Answer", "text": "We can import your contacts, scripts and history into the SyncAgency format. An export from Infloww plus a guided import is all it takes. Nothing is lost." } },
    { "@type": "Question", "name": "Do my chatters need to reconnect?", "acceptedAnswer": { "@type": "Answer", "text": "No. Your chatters keep working from their usual interface. You're the one switching tools on the agency side — they don't see a thing." } },
    { "@type": "Question", "name": "What exactly is the Empire OS plan?", "acceptedAnswer": { "@type": "Answer", "text": "Empire OS = Core Chatting (Telegram/WhatsApp CRM, Vault, Mass DM, 20% payments) + Growth Marketing (Instagram/TikTok/Twitter tracking, attribution, A/B testing) in a single plan at €129/model/month." } }
  ]
};
---

<BaseLayout lang="en"
  title="Migrate from Infloww to SyncAgency — 7 days free"
  description="Using Infloww? Here's why OFM agencies migrate to SyncAgency. Native Telegram, 20% commission, dedicated support. Free assisted migration."
  pageKey="crm"
  ogImage="/og/og-migration.png"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  </Fragment>

  <style>
    /* ── Pain cards ─────────────────────────────────────────────── */
    .pain-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      max-width: 880px;
      margin: 0 auto;
    }
    .pain-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px;
      padding: 32px;
    }
    .pain-card-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: rgba(138,165,255,0.10);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #8AA5FF;
      margin-bottom: 16px;
    }
    .pain-card-title {
      font-size: 17px;
      font-weight: 700;
      color: #F2F2F2;
      margin-bottom: 10px;
    }
    .pain-card-body {
      font-size: 14px;
      color: #999;
      line-height: 1.7;
    }

    /* ── Pivot section ─────────────────────────────────────────── */
    .pivot-text {
      font-size: 36px;
      font-weight: 800;
      color: #F2F2F2;
      line-height: 1.15;
      max-width: 640px;
      margin: 0 auto 16px;
    }
    .pivot-text-2 {
      font-size: 28px;
      font-weight: 700;
      color: #8AA5FF;
      max-width: 640px;
      margin: 0 auto 24px;
    }
    .pivot-support {
      font-size: 16px;
      color: #737373;
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* ── Comparative table ─────────────────────────────────────── */
    .vs-table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .vs-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 560px;
    }
    .vs-th {
      padding: 16px 20px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-align: center;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .vs-th-feature { text-align: left; color: #999; width: 45%; }
    .vs-th-sync { background: rgba(138,165,255,0.06); border-radius: 12px 12px 0 0; color: #8AA5FF; width: 27.5%; }
    .vs-th-comp { color: #737373; width: 27.5%; }
    .vs-th-logo { display: block; font-size: 15px; margin-bottom: 4px; }
    .vs-th-badge { display: inline-block; background: rgba(138,165,255,0.15); color: #8AA5FF; font-size: 10px; letter-spacing: 0.08em; padding: 2px 8px; border-radius: 6px; text-transform: uppercase; }
    .vs-table tbody tr:hover td { background: rgba(255,255,255,0.02); }
    .vs-table tbody tr td { padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 14px; transition: background 0.15s; }
    .vs-td-feature { color: #999; text-align: left; }
    .vs-td-sync { text-align: center; background: rgba(138,165,255,0.03); color: #F2F2F2; font-weight: 500; }
    .vs-td-comp { text-align: center; color: #737373; }
    .vs-check { color: #8AA5FF; font-weight: 600; }
    .vs-cross { color: #555; }
    .vs-partial { color: #F59E0B; font-size: 12px; }

    /* ── Eco section ───────────────────────────────────────────── */
    .eco-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      max-width: 880px;
      margin: 0 auto 40px;
    }
    .eco-card {
      border-radius: 20px;
      padding: 36px;
      text-align: center;
    }
    .eco-card--before {
      background: rgba(255,255,255,0.025);
      border: 1px solid rgba(255,255,255,0.06);
    }
    .eco-card--after {
      background: rgba(138,165,255,0.07);
      border: 1px solid rgba(138,165,255,0.20);
    }
    .eco-card-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #737373;
      margin-bottom: 16px;
    }
    .eco-card--after .eco-card-label { color: #8AA5FF; }
    .eco-card-stat {
      font-size: 52px;
      font-weight: 800;
      color: #555;
      line-height: 1;
      margin-bottom: 12px;
    }
    .eco-card--after .eco-card-stat { color: #8AA5FF; }
    .eco-card-desc {
      font-size: 14px;
      color: #737373;
      line-height: 1.65;
    }
    .eco-card--after .eco-card-desc { color: #999; }
    .eco-conclusion {
      text-align: center;
      padding: 24px 32px;
      background: rgba(138,165,255,0.06);
      border: 1px solid rgba(138,165,255,0.15);
      border-radius: 14px;
      max-width: 560px;
      margin: 0 auto;
      font-size: 18px;
      font-weight: 700;
      color: #F2F2F2;
    }

    /* ── Pricing card ──────────────────────────────────────────── */
    .empire-card {
      max-width: 480px;
      margin: 0 auto;
      background: rgba(138,165,255,0.05);
      border: 1px solid rgba(138,165,255,0.25);
      border-radius: 24px;
      padding: 48px 40px;
      text-align: center;
    }
    .empire-card-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(138,165,255,0.10);
      border: 1px solid rgba(138,165,255,0.20);
      border-radius: 20px;
      padding: 5px 14px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      color: #8AA5FF;
      margin-bottom: 24px;
    }
    .empire-card-price {
      font-size: 56px;
      font-weight: 800;
      color: #F2F2F2;
      line-height: 1;
      margin-bottom: 4px;
    }
    .empire-card-price-sub {
      font-size: 14px;
      color: #737373;
      margin-bottom: 32px;
    }
    .empire-card-features {
      list-style: none;
      padding: 0;
      margin: 0 0 36px;
      text-align: left;
    }
    .empire-card-features li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 15px;
      color: #999;
      padding: 9px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .empire-card-features li:last-child { border-bottom: none; }
    .empire-card-features li .check { color: #8AA5FF; font-weight: 700; flex-shrink: 0; }
    .empire-card-note {
      margin-top: 16px;
      font-size: 12px;
      color: #555;
    }

    /* ── FAQ ───────────────────────────────────────────────────── */
    .faq-list {
      max-width: 720px;
      margin: 0 auto;
    }
    .faq-item {
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 24px 0;
    }
    .faq-q {
      font-size: 17px;
      font-weight: 600;
      color: #F2F2F2;
      margin-bottom: 10px;
    }
    .faq-a {
      font-size: 15px;
      color: #737373;
      line-height: 1.7;
    }

    @media (max-width: 768px) {
      .pain-grid { grid-template-columns: 1fr; }
      .eco-grid { grid-template-columns: 1fr; }
      .pivot-text { font-size: 28px; }
      .eco-card-stat { font-size: 40px; }
    }
  </style>

  <!-- ── Section 1 : Hero ──────────────────────────────────────────────────── -->
  <section class="section section--hero spotlight-zone" id="hero-migration">
    <div class="glow-blobs">
      <div class="glow-blob glow-blob-1"></div>
      <div class="glow-blob glow-blob-2"></div>
    </div>
    <div class="container fade-in-up" style="max-width: 760px; text-align: center;">
      <p class="eyebrow" style="margin-bottom:24px;">
        Migration from Infloww &nbsp;•&nbsp; 7-day free trial &nbsp;•&nbsp; Assisted migration
      </p>
      <h1 class="section-title" style="font-size:52px;font-weight:800;line-height:1.08;margin-bottom:20px;">
        On Infloww? Here's why agencies are migrating to SyncAgency.
      </h1>
      <p class="section-subtitle" style="max-width:580px;margin:0 auto 48px;">
        Infloww is good for onsite. SyncAgency is built for off-platform — where the real money is made.
      </p>
      <div style="display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;">
        <a
          href="https://app.syncagency.fr/register?plan=empire_os"
          class="btn-primary"
          data-cta="migration_hero_main"
          data-section="migration_hero"
        >
          Start your free migration →
        </a>
        <a
          href="#vs-infloww-migration"
          style="font-size:15px;color:#737373;text-decoration:none;font-weight:500;transition:color 0.2s;"
          onmouseover="this.style.color='#F2F2F2'" onmouseout="this.style.color='#737373'"
        >
          See the comparison ↓
        </a>
      </div>
    </div>
  </section>

  <!-- ── Section 2 : Infloww pain points ──────────────────────────────────── -->
  <section class="section section--pain" style="background:#080808;" id="douleurs-infloww">
    <div class="container">
      <div style="text-align:center;margin-bottom:56px;">
        <p class="eyebrow" style="margin-bottom:12px;">Why migrate</p>
        <h2 class="section-title" style="margin-bottom:16px;">4 Infloww limitations you feel every day.</h2>
      </div>
      <div class="pain-grid">
        <div class="pain-card">
          <div class="pain-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <p class="pain-card-title">40% commission</p>
          <p class="pain-card-body">
            OnlyFans, MYM, Fansly take 40% on your sales. Infloww doesn't integrate any alternative processor. You're stuck with the platform's cut.
          </p>
        </div>
        <div class="pain-card">
          <div class="pain-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>
            </svg>
          </div>
          <p class="pain-card-title">No native Telegram</p>
          <p class="pain-card-body">
            Your chatters chat on Telegram? Infloww isn't built for that. You juggle two tools, lose context, and miss sales.
          </p>
        </div>
        <div class="pain-card">
          <div class="pain-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <p class="pain-card-title">Slow, generic support</p>
          <p class="pain-card-body">
            When you hit a bug at 2 a.m. on a Saturday, a slow ticket queue isn't what you need. The SyncAgency team is responsive and hands-on.
          </p>
        </div>
        <div class="pain-card">
          <div class="pain-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <p class="pain-card-title">Platform lock-in</p>
          <p class="pain-card-body">
            Infloww is designed for OnlyFans. If your models move to Fansly, MYM or a private platform, you rebuild everything.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Section 3 : Pivot ─────────────────────────────────────────────────── -->
  <section class="section section--key spotlight-zone" id="pivot">
    <div class="glow-blobs">
      <div class="glow-blob glow-blob-1"></div>
      <div class="glow-blob glow-blob-2"></div>
    </div>
    <div class="container fade-in-up" style="text-align:center;">
      <p class="pivot-text">The real problem isn't Infloww.</p>
      <p class="pivot-text-2">It's that it was never built for off-platform.</p>
      <p class="pivot-support">
        Telegram, WhatsApp, private platforms — that's where modern OFM agencies make their real margins. SyncAgency is the only CRM built for that use case.
      </p>
    </div>
  </section>

  <!-- ── Section 4 : Comparison ────────────────────────────────────────────── -->
  <section class="section section--key" id="vs-infloww-migration" style="background:#050505;">
    <div class="container">
      <div style="text-align:center;margin-bottom:56px;">
        <p class="eyebrow" style="margin-bottom:12px;">Comparison</p>
        <h2 class="section-title" style="margin-bottom:16px;">The honest comparison.</h2>
        <p style="font-size:16px;color:#999;max-width:480px;margin:0 auto;line-height:1.6;">
          Feature by feature. No spin.
        </p>
      </div>
      <div class="vs-table-wrap">
        <table class="vs-table">
          <thead>
            <tr>
              <th class="vs-th vs-th-feature">Feature</th>
              <th class="vs-th vs-th-sync">
                <span class="vs-th-logo">SyncAgency</span>
                <span class="vs-th-badge">Our pick</span>
              </th>
              <th class="vs-th vs-th-comp">Infloww</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="vs-td-feature">Optimized for native Telegram</td>
              <td class="vs-td-sync"><span class="vs-check">✓</span></td>
              <td class="vs-td-comp"><span class="vs-cross">✗</span></td>
            </tr>
            <tr>
              <td class="vs-td-feature">Media vault + scripts</td>
              <td class="vs-td-sync"><span class="vs-check">✓</span></td>
              <td class="vs-td-comp"><span class="vs-cross">✗</span></td>
            </tr>
            <tr>
              <td class="vs-td-feature">Segmented Mass DM</td>
              <td class="vs-td-sync"><span class="vs-check">✓</span></td>
              <td class="vs-td-comp"><span class="vs-partial">Limited</span></td>
            </tr>
            <tr>
              <td class="vs-td-feature">Processor commission</td>
              <td class="vs-td-sync"><span class="vs-check">20%</span> fan side</td>
              <td class="vs-td-comp"><span class="vs-cross">40%</span> agency side</td>
            </tr>
            <tr>
              <td class="vs-td-feature">Real-time notifications</td>
              <td class="vs-td-sync"><span class="vs-check">✓</span></td>
              <td class="vs-td-comp"><span class="vs-partial">Delayed</span></td>
            </tr>
            <tr>
              <td class="vs-td-feature">Tracking Links attribution</td>
              <td class="vs-td-sync"><span class="vs-check">✓ Included</span></td>
              <td class="vs-td-comp"><span class="vs-cross">Add-on</span></td>
            </tr>
            <tr>
              <td class="vs-td-feature">Dedicated support</td>
              <td class="vs-td-sync"><span class="vs-check">✓</span></td>
              <td class="vs-td-comp"><span class="vs-cross">Generic</span></td>
            </tr>
            <tr>
              <td class="vs-td-feature">Free assisted migration</td>
              <td class="vs-td-sync"><span class="vs-check">✓ Empire OS</span></td>
              <td class="vs-td-comp"><span class="vs-cross">✗</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <div style="text-align:center;margin-top:48px;">
        <a href="https://app.syncagency.fr/register?plan=empire_os" class="btn-primary" data-cta="migration_table_cta" data-section="vs_infloww_migration">
          Start your free migration →
        </a>
      </div>
    </div>
  </section>

  <!-- ── Section 5 : Economic argument ─────────────────────────────────────── -->
  <section class="section section--pain" style="background:#080808;" id="eco-argument">
    <div class="container">
      <div style="text-align:center;margin-bottom:56px;">
        <p class="eyebrow" style="margin-bottom:12px;">Financial impact</p>
        <h2 class="section-title" style="margin-bottom:16px;">What it changes on €100k/month.</h2>
      </div>
      <div class="eco-grid">
        <div class="eco-card eco-card--before">
          <p class="eco-card-label">With Infloww</p>
          <p class="eco-card-stat">€40,000</p>
          <p class="eco-card-desc">
            You pay 40% to OnlyFans/MYM on your €100k of PPV sales. That's <strong style="color:#F2F2F2;">€40,000</strong> in platform commission — taken straight out of your margin.
          </p>
        </div>
        <div class="eco-card eco-card--after">
          <p class="eco-card-label">With SyncAgency</p>
          <p class="eco-card-stat">€20,000</p>
          <p class="eco-card-desc">
            You pay 20% to SyncAgency on your sales. That's <strong style="color:#F2F2F2;">€20,000</strong> in commission. You recover <strong style="color:#8AA5FF;">€20,000/month</strong> in margin.
          </p>
        </div>
      </div>
      <div class="eco-conclusion">
        Over 12 months: +€240,000 in recovered revenue.
      </div>
    </div>
  </section>

  <!-- ── Section 6 : Pricing / Migration CTA ───────────────────────────────── -->
  <section class="section section--key spotlight-zone" id="migration-cta" style="background:#050505;">
    <div class="glow-blobs">
      <div class="glow-blob glow-blob-1"></div>
      <div class="glow-blob glow-blob-2"></div>
    </div>
    <div class="container fade-in-up" style="text-align:center;">
      <h2 class="section-title" style="background:linear-gradient(135deg,#8AA5FF,#A8BBFF);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:48px;">
        Free migration. 7-day trial. Zero risk.
      </h2>
      <div class="empire-card">
        <div class="empire-card-badge">Empire OS</div>
        <p class="empire-card-price">€129</p>
        <p class="empire-card-price-sub">/model/month</p>
        <ul class="empire-card-features">
          <li><span class="check">✓</span> Full Chatting CRM</li>
          <li><span class="check">✓</span> Growth Marketing</li>
          <li><span class="check">✓</span> Assisted data migration</li>
          <li><span class="check">✓</span> Priority support</li>
          <li><span class="check">✓</span> Personalized onboarding</li>
        </ul>
        <a
          href="https://app.syncagency.fr/register?plan=empire_os"
          class="btn-primary"
          data-cta="migration_pricing_cta"
          data-section="migration_pricing"
          style="width:100%;display:block;text-align:center;"
        >
          Start your free migration →
        </a>
        <p class="empire-card-note">7 days free, no credit card required</p>
      </div>
    </div>
  </section>

  <!-- ── Section 7 : Migration FAQ ─────────────────────────────────────────── -->
  <section class="section section--pain" style="background:#080808;" id="faq-migration">
    <div class="container">
      <div style="text-align:center;margin-bottom:56px;">
        <p class="eyebrow" style="margin-bottom:12px;">FAQ</p>
        <h2 class="section-title" style="margin-bottom:16px;">Questions about migrating.</h2>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <p class="faq-q">How long does the migration take?</p>
          <p class="faq-a">
            Usually 24 to 48 hours depending on data volume. A SyncAgency team member walks you through it step by step. You don't migrate alone.
          </p>
        </div>
        <div class="faq-item">
          <p class="faq-q">What about my Infloww data — history, contacts, scripts?</p>
          <p class="faq-a">
            We can import your contacts, scripts and history into the SyncAgency format. An export from Infloww plus a guided import is all it takes. Nothing is lost.
          </p>
        </div>
        <div class="faq-item">
          <p class="faq-q">Do my chatters need to reconnect?</p>
          <p class="faq-a">
            No. Your chatters keep working from their usual interface. You're the one switching tools on the agency side — they don't see a thing.
          </p>
        </div>
        <div class="faq-item">
          <p class="faq-q">What exactly is the Empire OS plan?</p>
          <p class="faq-a">
            Empire OS = Core Chatting (Telegram/WhatsApp CRM, Vault, Mass DM, 20% payments) + Growth Marketing (Instagram/TikTok/Twitter tracking, attribution, A/B testing) in a single plan at €129/model/month.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
