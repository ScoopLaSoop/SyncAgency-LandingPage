---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import PainCards from '@/components/sections/PainCards.astro';
import PivotDiagnostic from '@/components/sections/PivotDiagnostic.astro';
import SolutionSection from '@/components/sections/SolutionSection.astro';
import ReviewCards from '@/components/sections/ReviewCards.astro';
import PricingCards from '@/components/sections/PricingCards.astro';
import FAQ from '@/components/sections/FAQ.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('landings', 'en/marketing');
if (!entry) throw new Error('Marketing landing data not found');
const data = entry.data;

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do I connect my Instagram, TikTok, and Twitter accounts?", "acceptedAnswer": { "@type": "Answer", "text": "You just enter the @username of your public accounts in the dashboard. No credentials to hand over, no OAuth to validate, no app to connect. The scraping runs on the public pages of each network, like an intelligent crawler that monitors and collects the data for you." } },
    { "@type": "Question", "name": "How often is the scraping updated?", "acceptedAnswer": { "@type": "Answer", "text": "Once a day. Every morning, you find the new data of your accounts (views, likes, comments, saves, shares) refreshed in your dashboard. The daily rhythm is more than enough to steer your content strategy." } },
    { "@type": "Question", "name": "How many accounts can I connect per model?", "acceptedAnswer": { "@type": "Answer", "text": "The Growth Marketing plan includes 2 Instagram accounts + 2 Twitter accounts + 2 TikTok accounts per model. If your models have more accounts, you can add add-ons: +5€/month for a Twitter account, +10€/month for Instagram, +17€/month for TikTok." } },
    { "@type": "Question", "name": "How does automated A/B testing work?", "acceptedAnswer": { "@type": "Answer", "text": "You publish several versions of the same post on your accounts. SyncAgency tracks the performance of each one in parallel: views, engagement rate, clicks on your bio, fans brought in. You get a clear comparison within a few days, without compiling a spreadsheet by hand." } },
    { "@type": "Question", "name": "How many tracking links can I create?", "acceptedAnswer": { "@type": "Answer", "text": "Unlimited tracking links on the Growth Marketing and Empire OS plans. Create a link per post, per bio, per campaign, per story, with no limit at all. Each link gives you the click counter, the geographic source, the device, and the revenue generated if the click leads to a sale." } },
    { "@type": "Question", "name": "Is my data and my models' data private?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All your data is hosted in France, encrypted at rest and in transit. No data is shared with other agencies or used to train third-party models. You can export everything at any time." } },
    { "@type": "Question", "name": "Why 89€ per month and per model?", "acceptedAnswer": { "@type": "Answer", "text": "Because that's the cost of running a service that scrapes Instagram, TikTok, and Twitter every day, that maintains unlimited tracking links, that calculates funnel attribution, and that delivers it all to you in a unified dashboard." } }
  ]
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.syncagency.fr/en/" },
    { "@type": "ListItem", "position": 2, "name": "Marketing", "item": "https://www.syncagency.fr/en/marketing" }
  ]
};
---

<BaseLayout lang="en"
  title={data.meta.title}
  description={data.meta.description}
  pageKey="marketing"
  ogImage="/og/og-marketing-en.png"
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/assets/videos/vsl-marketing-poster.jpg" fetchpriority="high" />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  </Fragment>
  <Hero data={data.hero} pageKey="marketing" ctaDataAttr="hero-7days-free" lang="en" />
  <PainCards
    title={data.painSection.title}
    cards={data.painSection.cards}
    bridgeText={data.painSection.bridgeText}
  />
  <PivotDiagnostic data={data.pivot} />
  <SolutionSection
    introTitle={data.solution.introTitle}
    items={data.solution.items}
    idPrefix="solution-m"
    mode="marketing"
    lang="en"
  />
  <ReviewCards
    mode="marketing"
    title={data.reviews.title}
    subtitle={data.reviews.subtitle}
    trust={data.reviews.trust}
    cards={data.reviews.cards}
    transitionText={data.reviews.transitionText}
  />
  <PricingCards
    title={data.pricing.title}
    subtitle={data.pricing.subtitle}
    plans={data.pricing.plans}
    guarantees={data.pricing.guarantees}
    transitionText={data.pricing.transitionText}
    mode="marketing"
  />
  <FAQ
    title={data.faq.title}
    subtitle={data.faq.subtitle}
    items={data.faq.items}
    contact={data.faq.contact}
    idPrefix="faqm"
    lang="en"
  />

  <!-- Affiliation banner -->
  <section class="section affi-bandeau" style="background: #050505;">
    <div class="container fade-in-up">
      <div class="affi-bandeau-inner">
        <div class="affi-bandeau-text">
          <p class="affi-bandeau-eyebrow">Affiliate program</p>
          <h2 class="affi-bandeau-title">Got a network of OFM agencies?</h2>
          <p class="affi-bandeau-sub">Earn <strong>10% recurring commission</strong> on every agency you refer to us on the Growth Marketing plan. No commitment, monthly payment.</p>
        </div>
        <a href="/en/affiliation?plan=marketing" class="btn-primary affi-bandeau-cta" data-cta="affiliation_bandeau" data-section="marketing_footer">
          Discover the program →
        </a>
      </div>
    </div>
  </section>

  <!-- Marketing module video transcripts — crawlable by LLMs -->
  <section id="transcripts-marketing" aria-label="Marketing demo transcripts" style="background: #050505; padding: 60px 0;">
    <div class="container" style="max-width: 880px;">
      <h2 style="font-size: 18px; font-weight: 600; color: #F2F2F2; margin-bottom: 8px;">Demo transcripts</h2>
      <p style="font-size: 14px; color: #555; margin-bottom: 32px;">For screen readers and AI assistants.</p>

      <details class="transcript-item">
        <summary>Demo — Marketing accounts &amp; scraping (Instagram, TikTok, Twitter)</summary>
        <div class="transcript-content">
          <p>SyncAgency's Growth Marketing module centralizes the analysis of your social media accounts. You enter the @username of your Instagram, TikTok, and Twitter accounts in the dashboard. No credentials to hand over, no OAuth to validate.</p>
          <p>The scraping runs every day on the public pages. Every morning, you find the new metrics refreshed: views, likes, comments, saves, shares — for every post of every account of every model.</p>
          <p>Included per model: 2 Instagram accounts, 2 Twitter accounts, 2 TikTok accounts. Add-ons are available if your models have more accounts.</p>
        </div>
      </details>

      <details class="transcript-item">
        <summary>Demo — Publication calendar &amp; team management</summary>
        <div class="transcript-content">
          <p>SyncAgency includes an editorial calendar that centralizes all the published and scheduled posts of your creators. Every member of your team sees the schedule in real time.</p>
          <p>You assign posts to your Social Media Managers by model. The calendar gives you a clear view of publication frequency, optimal time slots, and gaps in your content schedule.</p>
        </div>
      </details>

      <details class="transcript-item">
        <summary>Demo — Per-post performance analysis</summary>
        <div class="transcript-content">
          <p>Every post imported from Instagram, TikTok, or Twitter is analyzed individually. You see the key metrics: views, engagement, saves, shares — and you compare performance across posts of the same model.</p>
          <p>Automated A/B testing compares several versions of the same type of content and gives you a clear comparison within a few days. You identify the formats that perform best without having to compile a spreadsheet.</p>
        </div>
      </details>

      <details class="transcript-item">
        <summary>Demo — Tracking Links &amp; sales attribution</summary>
        <div class="transcript-content">
          <p>SyncAgency generates unique tracking links that you place in the bios, the stories, or the posts of your models. Every click is tracked with the source (IG, TikTok, Twitter), the device, the geographic location.</p>
          <p>When a click on a tracking link leads to a sale in the inbox, the sale is automatically attributed to the source. You know exactly which post, which bio, which campaign generated which revenue. Unlimited tracking links on the Growth Marketing and Empire OS plans.</p>
        </div>
      </details>

      <details class="transcript-item">
        <summary>Demo — Acquisition funnel &amp; global overview</summary>
        <div class="transcript-content">
          <p>SyncAgency's Funnel module visualizes the complete journey of a fan: from exposure to a post on social media, to the click on the bio, to entering the Telegram inbox, all the way to the first sale.</p>
          <p>You identify the friction points in your acquisition. How many fans come in via IG vs TikTok? Which network generates the most active fans? Which model has the best post → inbox → sale conversion rate?</p>
        </div>
      </details>

      <details class="transcript-item">
        <summary>Demo — Scraped posts &amp; content inspiration</summary>
        <div class="transcript-content">
          <p>SyncAgency also scrapes the posts of the public accounts of your competitors or of reference creators. You build a content inspiration library directly in the dashboard.</p>
          <p>You identify the viral formats in your niche, the types of posts that generate the most saves and shares, and you adapt your editorial strategy accordingly. All without leaving SyncAgency.</p>
        </div>
      </details>
    </div>
  </section>

  <style>
    /* Transcripts (shared styles if not already defined in this file) */
    .transcript-item {
      background: rgba(10, 13, 26, 0.5);
      border: 1px solid rgba(38, 38, 38, 0.5);
      border-radius: 12px;
      padding: 16px 24px;
      margin-bottom: 10px;
    }
    .transcript-item summary {
      cursor: pointer;
      font-weight: 600;
      font-size: 14px;
      color: #F2F2F2;
      list-style: none;
      user-select: none;
    }
    .transcript-item summary::-webkit-details-marker { display: none; }
    .transcript-item summary::before { content: '+ '; color: #8AA5FF; font-weight: 700; }
    .transcript-item[open] summary::before { content: '− '; }
    .transcript-content {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .transcript-content p {
      font-size: 14px;
      color: #666;
      line-height: 1.7;
      margin-bottom: 12px;
    }
    .transcript-content p:last-child { margin-bottom: 0; }
  </style>
</BaseLayout>
