---
interface HeroData {
  eyebrow: string;
  h1: string;
  subtitle: string;
  ctaText: string;
  ctaUrl: string;
  reassurance: string;
  proofBadge: string;
}

interface Props {
  data: HeroData;
  pageKey?: 'crm' | 'marketing';
  ctaDataAttr?: string;
}

const { data, pageKey = 'crm', ctaDataAttr = 'hero-cta' } = Astro.props;
---

<section class="section section--hero spotlight-zone" id="hero">
  <div class="glow-blobs">
    <div class="glow-blob glow-blob-1"></div>
    <div class="glow-blob glow-blob-2"></div>
  </div>
  <div class="container hero-inner hero-inner--centered">
    <div class="hero-text fade-in-up">
      <p class="hero-eyebrow eyebrow eyebrow--animated" set:html={data.eyebrow} />
      <h1 class="hero-h1">{data.h1}</h1>
      <p class="hero-subtitle" set:html={data.subtitle} />
      <div class="hero-cta-group">
        <a href={data.ctaUrl} class="btn-primary" data-cta={ctaDataAttr} data-section="hero">
          {data.ctaText}
        </a>
        <p class="hero-reassurance">{data.reassurance}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-inner--centered {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-inner--centered .hero-text {
    text-align: center;
    max-width: 720px;
  }
  .hero-inner--centered .hero-cta-group {
    justify-content: center;
  }
</style>
