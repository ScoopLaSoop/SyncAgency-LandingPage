---
interface PainCard {
  icon: string;      // nom icône Lucide (ex: 'layout-grid')
  title: string;
  description: string;
}

interface Props {
  title: string;
  cards: PainCard[];
  bridgeText: string;
}

const { title, cards, bridgeText } = Astro.props;
---

<section class="section section--pain" id="bandeau">
  <div class="container">
    <h2 class="section-title fade-in-up">{title}</h2>
    <div class="pain-grid">
      {cards.map((card, i) => (
        <div class={`card pain-card fade-in-up delay-${i + 1}`}>
          <i data-lucide={card.icon} class="card-icon" aria-hidden="true"></i>
          <h3 class="card-title" set:html={card.title} />
          <p class="card-desc" set:html={card.description} />
        </div>
      ))}
    </div>
    <p class="pivot-phrase fade-in-up" set:html={bridgeText} />
  </div>
</section>
