---
// src/pages/_preview.astro
// Page de preview — non indexée dans le sitemap
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Component Preview — SyncAgency Astro</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <style>
    /* Inline les tokens essentiels pour éviter l'import circular */
    :root {
      --color-primary: #8AA5FF;
      --color-primary-hover: #A3BCFF;
      --color-bg-base: #050505;
      --color-text-primary: #F2F2F2;
      --color-text-secondary: #999999;
      --color-text-tertiary: #737373;
      --color-text-muted: #555555;
      --color-muted: #555555;
      --color-bg-card: #0A0D1A;
      --color-bg-elevated: #171A21;
      --color-border-default: #2E2E2E;
      --font-family: 'Inter', system-ui, sans-serif;
      --radius-sm: 6px;
      --radius-md: 8px;
      --radius-lg: 12px;
      --radius-xl: 16px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #050505;
      color: #F2F2F2;
      font-family: Inter, system-ui, sans-serif;
      padding: 40px 24px 80px;
    }

    h1 {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 48px;
    }

    .preview-section {
      margin-bottom: 64px;
      border-bottom: 1px solid #2E2E2E;
      padding-bottom: 64px;
    }

    .preview-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #737373;
      margin-bottom: 24px;
    }

    .preview-row {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      align-items: flex-start;
    }

    /* ── Buttons ─────────────────────────────────────────────────────────────── */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      border-radius: var(--radius-lg);
      font-size: 15px;
      font-weight: 600;
      color: #fff;
      background: linear-gradient(135deg, #3B5BFF 0%, #8AA5FF 100%);
      text-decoration: none;
      transition: opacity 0.2s ease, box-shadow 0.2s ease;
      box-shadow: 0 0 24px rgba(59, 91, 255, 0.35);
    }
    .btn-primary:hover {
      opacity: 0.9;
      box-shadow: 0 0 40px rgba(59, 91, 255, 0.50);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      border-radius: var(--radius-lg);
      font-size: 15px;
      font-weight: 600;
      color: var(--color-text-primary);
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.12);
      text-decoration: none;
      transition: background 0.2s ease, border-color 0.2s ease;
    }
    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.20);
    }

    .btn-tertiary {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 16px;
      font-size: 14px;
      font-weight: 500;
      color: var(--color-text-secondary);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .btn-tertiary:hover { color: var(--color-primary-hover); }

    .pricing-cta-soon {
      display: inline-block;
      padding: 10px 20px;
      border-radius: 12px;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--color-muted);
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      cursor: not-allowed;
    }

    /* ── Eyebrow ─────────────────────────────────────────────────────────────── */
    .eyebrow {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-primary);
      background: rgba(138, 165, 255, 0.08);
      border: 1px solid rgba(138, 165, 255, 0.20);
      border-radius: 100px;
      padding: 6px 16px;
    }

    /* ── Badge Plan ──────────────────────────────────────────────────────────── */
    .badge-plan {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      border-radius: 4px;
      padding: 4px 10px;
    }
    .badge-plan--crm {
      background: rgba(138, 165, 255, 0.12);
      color: var(--color-primary);
      border: 1px solid rgba(138, 165, 255, 0.25);
    }
    .badge-plan--marketing {
      background: rgba(34, 197, 94, 0.10);
      color: #22C55E;
      border: 1px solid rgba(34, 197, 94, 0.20);
    }
    .badge-plan--empire {
      background: rgba(251, 191, 36, 0.10);
      color: #F59E0B;
      border: 1px solid rgba(251, 191, 36, 0.20);
    }

    /* ── Accordion ───────────────────────────────────────────────────────────── */
    .accordion-item {
      background: rgba(10, 13, 26, 0.50);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border: 1px solid rgba(38, 38, 38, 0.40);
      border-radius: var(--radius-lg);
      overflow: hidden;
      transition: border-color 0.3s ease;
      margin-bottom: 8px;
      list-style: none;
    }
    .accordion-item:hover { border-color: rgba(138, 165, 255, 0.30); }

    .accordion-trigger {
      width: 100%;
      background: transparent;
      border: none;
      padding: 24px 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      font-family: var(--font-family);
      font-weight: 600;
      font-size: 18px;
      color: var(--color-text-primary);
      text-align: left;
      gap: 16px;
    }

    .accordion-icon {
      width: 20px;
      height: 20px;
      color: var(--color-text-tertiary);
      transition: transform 0.2s ease, color 0.2s ease;
      flex-shrink: 0;
    }
    details.accordion-item[open] .accordion-icon {
      transform: rotate(180deg);
      color: var(--color-primary);
    }
    details.accordion-item summary { list-style: none; cursor: pointer; }
    details.accordion-item summary::-webkit-details-marker { display: none; }

    .accordion-content {
      max-height: none;
      overflow: visible;
    }
    details.accordion-item:not([open]) .accordion-content { display: none; }

    .accordion-body {
      padding: 0 32px 24px;
      font-family: var(--font-family);
      font-size: 16px;
      font-weight: 400;
      color: var(--color-text-secondary);
      line-height: 1.6;
    }

    /* ── Cards (glassmorphism) ───────────────────────────────────────────────── */
    .card {
      background: rgba(10, 13, 26, 0.50);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border: 1px solid rgba(38, 38, 38, 0.40);
      border-radius: var(--radius-lg);
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .card:hover {
      border-color: rgba(138, 165, 255, 0.40);
      box-shadow: 0 0 30px rgba(138, 165, 255, 0.15);
    }

    /* ── Pain Grid ───────────────────────────────────────────────────────────── */
    .pain-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
    .pain-card { padding: 32px; }

    .card-icon {
      width: 32px;
      height: 32px;
      color: var(--color-primary);
      filter: drop-shadow(0 0 6px rgba(138, 165, 255, 0.50));
      flex-shrink: 0;
    }
    .card-title {
      font-size: 20px;
      font-weight: 600;
      color: var(--color-text-primary);
      line-height: 1.3;
      margin-top: 16px;
      margin-bottom: 8px;
    }
    .card-desc {
      font-size: 15px;
      font-weight: 400;
      color: var(--color-text-secondary);
      line-height: 1.5;
    }

    /* ── Fade-in animation ───────────────────────────────────────────────────── */
    .fade-in-up {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .fade-in-up.in-view {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Pricing Card ────────────────────────────────────────────────────────── */
    .pricing-card {
      padding: 40px;
      border-radius: var(--radius-xl);
      display: flex;
      flex-direction: column;
      transition: box-shadow 0.3s ease, border-color 0.3s ease;
      background: rgba(10, 13, 26, 0.50);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border: 1px solid rgba(38, 38, 38, 0.40);
    }
    .pricing-card--current {
      position: relative;
      border-color: rgba(138, 165, 255, 0.50);
      box-shadow: 0 0 60px rgba(59, 91, 255, 0.20);
      transform: translateY(-8px);
    }
    .pricing-name {
      font-size: 24px;
      font-weight: 700;
      color: var(--color-text-primary);
      margin-bottom: 4px;
      margin-top: 16px;
    }
    .pricing-price {
      margin: 16px 0 4px;
    }
    .price-amount {
      font-size: 56px;
      font-weight: 700;
      color: var(--color-text-primary);
      line-height: 1;
      letter-spacing: -0.02em;
    }
    .price-meta {
      display: block;
      font-size: 14px;
      font-weight: 400;
      color: var(--color-text-tertiary);
      margin-top: 4px;
      margin-bottom: 28px;
    }
    .pricing-desc {
      font-size: 15px;
      font-weight: 400;
      color: var(--color-text-secondary);
      line-height: 1.5;
      margin: 24px 0 32px;
    }
    .feature-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
      list-style: none;
      padding: 0;
    }
    .feature-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }
    .feature-list li span {
      font-size: 14px;
      font-weight: 500;
      color: var(--color-text-primary);
      line-height: 1.4;
    }
    .feature-check {
      width: 16px;
      height: 16px;
      color: #22C55E;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .pricing-cta {
      display: block;
      margin-top: 32px;
      width: 100%;
      text-align: center;
      padding: 14px 24px;
      border-radius: var(--radius-lg);
      font-size: 15px;
      font-weight: 600;
      color: #fff;
      background: linear-gradient(135deg, #3B5BFF 0%, #8AA5FF 100%);
      text-decoration: none;
      box-shadow: 0 0 24px rgba(59, 91, 255, 0.35);
      transition: opacity 0.2s ease;
    }
    .pricing-cta:hover { opacity: 0.9; }

    /* ── Review Card ─────────────────────────────────────────────────────────── */
    .review-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.07);
      border-radius: 18px;
      padding: 28px 28px 24px;
    }
    .review-card-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 16px;
    }
    .review-avatar-photo {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
      border: 1.5px solid rgba(255, 255, 255, 0.10);
    }
    .review-card-name {
      font-size: 15px;
      font-weight: 600;
      color: var(--color-text-primary);
      display: block;
      line-height: 1.3;
    }
    .review-card-sub {
      font-size: 12px;
      color: var(--color-text-muted);
      margin-top: 2px;
      display: block;
    }
    .review-stars {
      color: var(--color-primary);
      font-size: 15px;
      letter-spacing: 2px;
      margin-bottom: 14px;
      line-height: 1;
    }
    .review-card-text {
      font-size: 14px;
      color: var(--color-text-secondary);
      line-height: 1.72;
      margin: 0;
    }

    /* ── Grid Background ─────────────────────────────────────────────────────── */
    .grid-background {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(138, 165, 255, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(138, 165, 255, 0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }
    .grid-background--subtle {
      opacity: 0.5;
    }
    .grid-background--strong {
      opacity: 1;
    }
  </style>
</head>
<body>
  <h1>SyncAgency — Component Preview</h1>

  <!-- ── Buttons ─────────────────────────────────────────────────────────── -->
  <div class="preview-section">
    <p class="preview-label">Buttons</p>
    <div class="preview-row">
      <a href="#" class="btn-primary">7 jours gratuits →</a>
      <a href="#" class="btn-secondary">Voir l'offre CRM →</a>
      <a href="#" class="btn-tertiary">Connexion</a>
      <span class="pricing-cta-soon">À venir</span>
    </div>
  </div>

  <!-- ── Eyebrow ──────────────────────────────────────────────────────────── -->
  <div class="preview-section">
    <p class="preview-label">Eyebrow</p>
    <span class="eyebrow">CRM Telegram • Chatting • Mass DM • Telegram Stars</span>
  </div>

  <!-- ── Badges Plan ──────────────────────────────────────────────────────── -->
  <div class="preview-section">
    <p class="preview-label">Badges Plan</p>
    <div class="preview-row">
      <span class="badge-plan badge-plan--crm">CRM TELEGRAM</span>
      <span class="badge-plan badge-plan--marketing">MARKETING</span>
      <span class="badge-plan badge-plan--empire">TOUT-EN-UN</span>
    </div>
  </div>

  <!-- ── Accordion ────────────────────────────────────────────────────────── -->
  <div class="preview-section">
    <p class="preview-label">Accordion (details/summary natif)</p>
    <div style="max-width: 640px;">
      <details class="accordion-item" open>
        <summary class="accordion-trigger">
          <span>C'est quoi SyncAgency ?</span>
          <span class="accordion-icon"><i data-lucide="chevron-down"></i></span>
        </summary>
        <div class="accordion-content">
          <div class="accordion-body">
            SyncAgency is the CRM for creator talent agencies that operate on Telegram.
          </div>
        </div>
      </details>
      <details class="accordion-item">
        <summary class="accordion-trigger">
          <span>Does SyncAgency work with WhatsApp?</span>
          <span class="accordion-icon"><i data-lucide="chevron-down"></i></span>
        </summary>
        <div class="accordion-content">
          <div class="accordion-body">
            Yes — SyncAgency supports both Telegram and WhatsApp natively.
          </div>
        </div>
      </details>
    </div>
  </div>

  <!-- ── Pain Cards (glassmorphism) ──────────────────────────────────────── -->
  <div class="preview-section">
    <p class="preview-label">Pain Cards (glassmorphism — classes : .card + .pain-card)</p>
    <div class="pain-grid">
      <div class="card pain-card fade-in-up in-view">
        <div class="card-icon"><i data-lucide="message-circle-x" style="width:32px;height:32px;stroke-width:1.5;"></i></div>
        <h3 class="card-title">Aucune visibilité sur tes convs.</h3>
        <p class="card-desc">Tu sais pas qui répond, qui chatte, qui performe.</p>
      </div>
      <div class="card pain-card fade-in-up in-view">
        <div class="card-icon"><i data-lucide="clock" style="width:32px;height:32px;stroke-width:1.5;"></i></div>
        <h3 class="card-title">Coordination manuelle chronophage.</h3>
        <p class="card-desc">Changements de shift par SMS, Excel, notes vocales.</p>
      </div>
    </div>
  </div>

  <!-- ── Pricing Card ─────────────────────────────────────────────────────── -->
  <div class="preview-section">
    <p class="preview-label">Pricing Card (classes : .pricing-card, .price-amount, .price-meta, .feature-list)</p>
    <div style="max-width: 360px; position: relative;">
      <div class="pricing-card pricing-card--current">
        <span class="badge-plan badge-plan--crm">CRM TELEGRAM</span>
        <h3 class="pricing-name">Core Chatting</h3>
        <div class="pricing-price">
          <span class="price-amount">59€</span>
          <span class="price-meta">/ creator / month</span>
        </div>
        <p class="pricing-desc">The CRM plan for serious agencies.</p>
        <ul class="feature-list">
          <li>
            <i data-lucide="check" class="feature-check"></i>
            <span>Tableau de bord opérateurs</span>
          </li>
          <li>
            <i data-lucide="check" class="feature-check"></i>
            <span>Shifts + planning</span>
          </li>
        </ul>
        <a href="#" class="pricing-cta">7 jours gratuits →</a>
      </div>
    </div>
  </div>

  <!-- ── Review Card ──────────────────────────────────────────────────────── -->
  <div class="preview-section">
    <p class="preview-label">Review Card (classes : .review-card, .review-card-header, .review-avatar-photo, .review-card-name, .review-card-sub, .review-card-text)</p>
    <div style="max-width: 520px;">
      <div class="review-card">
        <div class="review-card-header">
          <img
            src="/assets/images/review-luca.jpg"
            alt="Luca"
            class="review-avatar-photo"
            onerror="this.style.display='none'"
          />
          <div>
            <span class="review-card-name">Luca</span>
            <span class="review-card-sub">Agency founder — 3 creators</span>
          </div>
        </div>
        <div class="review-stars">★★★★★</div>
        <p class="review-card-text">"je gagnais beaucoup de temps depuis que j'utilise SyncAgency."</p>
      </div>
    </div>
  </div>

  <!-- ── Grid Background ──────────────────────────────────────────────────── -->
  <div class="preview-section" style="position:relative;min-height:200px;overflow:hidden;">
    <p class="preview-label" style="position:relative;z-index:1;">Grid Background (classe : .grid-background + .grid-background--subtle)</p>
    <div class="grid-background grid-background--subtle" aria-hidden="true"></div>
    <p style="position:relative;z-index:1;font-size:14px;color:#999;margin-top:12px;">Le fond de grille — généré par &lt;GridBackground /&gt;</p>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      if (window.lucide) lucide.createIcons();

      // Accordion single-open
      var allDetails = Array.from(document.querySelectorAll('details.accordion-item'));
      allDetails.forEach(function (details) {
        details.addEventListener('toggle', function () {
          if (details.open) {
            allDetails.forEach(function (other) {
              if (other !== details) other.removeAttribute('open');
            });
          }
        });
      });
    });
  </script>
</body>
</html>
