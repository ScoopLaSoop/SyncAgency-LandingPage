---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Empire OS — Coming Soon | SyncAgency"
  description="Operations CRM + Growth Marketing in a single plan. For creator agencies that want to manage everything from one place. Join the waitlist."
  pageKey="crm"
  ogImage="/og/og-empire.png"
>
  <style>
    .empire-hero {
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .empire-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(138,165,255,0.10);
      border: 1px solid rgba(138,165,255,0.20);
      border-radius: 20px;
      padding: 6px 16px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 24px;
    }
    .empire-badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--color-primary);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    .empire-title {
      font-size: 64px;
      font-weight: 800;
      line-height: 1.05;
      color: var(--color-text-primary);
      margin-bottom: 24px;
    }
    .empire-title .accent { color: var(--color-primary); }
    .empire-subtitle {
      font-size: 20px;
      color: var(--color-text-secondary, #999);
      line-height: 1.6;
      max-width: 560px;
      margin: 0 auto 48px;
    }
    .empire-features {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 32px;
      margin-bottom: 48px;
      flex-wrap: wrap;
    }
    .empire-feature {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 14px;
      color: var(--color-text-secondary, #999);
    }
    .empire-feature-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: rgba(138,165,255,0.10);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-primary);
      flex-shrink: 0;
    }
    .empire-feature-icon svg { width: 16px; height: 16px; stroke: currentColor; }
    .empire-price-note {
      margin-top: 24px;
      font-size: 13px;
      color: var(--color-text-muted, #555);
    }
    .empire-price-note strong { color: var(--color-primary); }
    @media (max-width: 768px) {
      .empire-title { font-size: 40px; }
      .empire-features { gap: 16px; }
    }
  </style>

  <section class="section section--hero spotlight-zone empire-hero" id="empire">
    <div class="glow-blobs">
      <div class="glow-blob glow-blob-1"></div>
      <div class="glow-blob glow-blob-2"></div>
    </div>
    <div class="container fade-in-up" style="max-width: 720px; text-align: center;">
      <div class="empire-badge">
        <span class="empire-badge-dot"></span>
        Coming soon
      </div>

      <h1 class="empire-title">
        SyncAgency <span class="accent">Empire OS</span> — Manage everything from one place.
      </h1>

      <p class="empire-subtitle">
        Operations CRM + Growth Marketing in a single plan.
        For creator agencies that want to centralize operations, acquisition, and payments — without juggling between multiple tools.
      </p>

      <div class="empire-features">
        <div class="empire-feature">
          <div class="empire-feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          Full Operations CRM
        </div>
        <div class="empire-feature">
          <div class="empire-feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
              <polyline points="17 6 23 6 23 12"/>
            </svg>
          </div>
          Growth Marketing
        </div>
        <div class="empire-feature">
          <div class="empire-feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          Free assisted migration
        </div>
      </div>

      <a
        href="mailto:contact@syncagency.fr?subject=Empire OS Waitlist"
        class="btn-primary"
        data-cta="empire_waitlist"
        data-section="empire_hero"
      >
        Join the waitlist →
      </a>

      <p class="empire-price-note">
        <strong>129€</strong>/creator/month &nbsp;•&nbsp; <strong>Core Operations + Growth Marketing</strong> included
      </p>
    </div>
  </section>
</BaseLayout>
